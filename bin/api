#!/usr/bin/env bash
# shell al contenidor api. usa -r per entrar com a root
set -euo pipefail
cd "$(dirname "$0")/../podman/php-infraestructura"
if [[ "${1:-}" == "-r" ]]; then
    shift
    podman compose --env-file .env exec -u root api bash "$@"
else
    podman compose --env-file .env exec api bash "$@"
fi
